{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Debug Backend (Spring Boot)",
      "request": "launch",
      "mainClass": "com.pm.backend.BackendApplication",
      "projectName": "backend",
      "cwd": "${workspaceFolder}/backend"
