{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend (Spring Boot)",
      "type": "shell",
      "command": ".\\gradlew.bat bootRun",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "backend"
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "Start Frontend (Vite)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "frontend"
      },
      "runOptions": {
        "runOn": "default"
      }
    },
    {
      "label": "Start Full Stack",
      "dependsOn": [
        "Start Backend (Spring Boot)",
        "Start Frontend (Vite)"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
